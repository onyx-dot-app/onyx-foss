################################################################################
## VÖB Extension Framework — Feature Flags
## Diese Variablen an die bestehende .env anfügen.
## Alle Flags sind default "false" (deaktiviert).
################################################################################

## Master-Switch: Aktiviert das Extension Framework.
## Wenn false, werden keine ext/-Router geladen und Onyx läuft unverändert.
EXT_ENABLED=false

## Modul-Flags (nur wirksam wenn EXT_ENABLED=true, AND-gated)
## Token Limits: Nutzungskontingente pro Benutzer/Gruppe
EXT_TOKEN_LIMITS_ENABLED=false

## RBAC: Rollen + Gruppen (Mapping auf Entra ID Abteilungen)
EXT_RBAC_ENABLED=false

## Analytics: Nutzungsstatistiken und Reporting
EXT_ANALYTICS_ENABLED=false

## Branding: Custom Logo, Titel, Farben
EXT_BRANDING_ENABLED=false

## Custom Prompts: System-Prompt-Erweiterungen
EXT_CUSTOM_PROMPTS_ENABLED=false

## Doc Access: Erweiterte Dokumentenzugriffskontrolle
EXT_DOC_ACCESS_ENABLED=false
